# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/cardgame

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_EXPIRES_IN=1h
REFRESH_SECRET=your_refresh_secret_change_me
REFRESH_EXPIRES_IN=7d

# Payment (Razorpay test keys)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx

# Admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123

# Game Settings
MIN_BET=10
MAX_BET=10000
BETTING_CLOSE_MINUTE=50
OVERRIDE_WINDOW_MINUTES=10
TIE_BREAKER_RULE=random   # or rank_order

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
